# Feast-AI Environment Variables
# Copy to .env and fill in values
# @version 1.0.1 - Integration cleanup

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/feast_ai
DIRECT_URL=postgresql://user:password@host:5432/feast_ai

# Auth (Clerk)
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# AI (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Twilio — inbound SMS webhook
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Inngest — background job pipelines
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Cache + Rate Limiting (Upstash)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Deepgram — audio transcription
DEEPGRAM_API_KEY=

# Email (Resend)
RESEND_API_KEY=re_...
FEAST_FROM_EMAIL=hello@feastongood.com

# Sentry — error tracking
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Production
NEXT_PUBLIC_API_URL=https://feast-ai-nine.vercel.app
