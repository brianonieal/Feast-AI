# Feast-AI Environment Variables
# Copy to .env and fill in values
# @version 0.1.0 - Foundation

# Database (Supabase PostgreSQL)
DATABASE_URL=postgresql://user:password@host:5432/feast_ai
DIRECT_URL=postgresql://user:password@host:5432/feast_ai

# Auth (Clerk)
CLERK_SECRET_KEY=sk_test_...
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
EXPO_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...

# AI (Anthropic)
ANTHROPIC_API_KEY=sk-ant-...

# Integrations — v0.2.0 Conduit
CIRCLE_API_KEY=
HUBSPOT_API_KEY=

# Twilio — v0.3.0 Signal
TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

# Inngest — v0.4.0 Spark
INNGEST_EVENT_KEY=
INNGEST_SIGNING_KEY=

# Cache + Rate Limiting — v0.4.0 Spark
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Content — v0.5.0 Echo
DEEPGRAM_API_KEY=
WORDPRESS_URL=
WORDPRESS_USERNAME=
WORDPRESS_APP_PASSWORD=

# v0.6.0 Beacon — Distribution
CIRCLE_PUBLIC_SPACE_ID=
CIRCLE_KITCHEN_SPACE_ID=
CIRCLE_FOUNDING_TABLE_SPACE_ID=
HUBSPOT_COMMUNITY_LIST_ID=
HUBSPOT_LIST_BROOKLYN=
FEAST_FROM_EMAIL=hello@feastongood.com
# Instagram deferred to v0.7.x (requires Meta app review + per-user OAuth)
# INSTAGRAM_ACCESS_TOKEN=
# INSTAGRAM_USER_ID=

# v0.7.0 Compass — Onboarding + Email
RESEND_API_KEY=re_...
